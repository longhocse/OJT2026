{
  "name": "ojt",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@hookform/resolvers": "^5.4.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "openai": "^6.45.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.0",
    "react-scripts": "5.0.1",
    "redux-persist": "^6.0.0",
    "web-vitals": "^2.1.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --runInBand",
    "test:coverage": "react-scripts test --watchAll=false --runInBand --coverage --coverageReporters=text --coverageReporters=lcov",
    "lint": "eslint src --ext .js,.jsx --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"*.{json,md}\"",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "react-hooks/exhaustive-deps": "error"
    },
    "overrides": [
      {
        "files": [
          "**/*.test.js",
          "**/*.test.jsx"
        ],
        "rules": {
          "import/first": "off",
          "no-script-url": "off"
        }
      }
    ]
  },
  "eslintIgnore": [
    "build",
    "coverage"
  ],
  "jest": {
    "collectCoverageFrom": [
      "src/services/**/*.{js,jsx}",
      "src/hooks/useAuth.js",
      "src/hooks/useSeatLock.js",
      "src/components/auth/**/*.{js,jsx}",
      "src/components/common/ProtectedRoute.jsx",
      "src/components/common/AdminRoute.jsx",
      "src/components/booking/SeatMap.jsx",
      "src/booking/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.6.2"
  }
}
