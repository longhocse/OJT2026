  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch src --ext js,json --exec node src/server.js",
    "test": "node --require ./test.setup.js --test --test-concurrency=1",
    "test:watch": "node --require ./test.setup.js --test --watch --test-concurrency=1",
    "test:coverage": "node --require ./test.setup.js --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-include=src/controllers/authController.js --test-coverage-include=src/controllers/bookingController.js --test-coverage-include=src/middleware/authMiddleware.js --test-coverage-include=src/middleware/errorHandler.js --test-coverage-include=src/middleware/validationMiddleware.js --test-concurrency=1",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security:check": "node scripts/check-secrets.js",
    "payos:webhook": "node scripts/confirm-payos-webhook.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1",
    "mssql": "^12.5.5",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
