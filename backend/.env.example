NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=replace-with-a-strong-database-password
DB_DATABASE=MovieTapDB
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
# DB_INSTANCE=SQLEXPRESS

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_MINUTES=60
FRONTEND_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM="MovieTap <your_gmail_address@gmail.com>"
SHOW_CLEANING_BUFFER_MINUTES=15
PAYMENT_PROVIDER_MODE=payos
PAYMENT_WEBHOOK_SECRET=replace-with-a-different-32-character-secret
PAYOS_CLIENT_ID=replace-with-payos-client-id
PAYOS_API_KEY=replace-with-payos-api-key
PAYOS_CHECKSUM_KEY=replace-with-payos-checksum-key
PAYOS_API_BASE_URL=https://api-merchant.payos.vn
# Update these whenever Cloudflare tunnel URLs change.
API_PUBLIC_URL=https://your-backend-cloudflare-url.trycloudflare.com
PAYOS_RETURN_URL=https://your-frontend-cloudflare-url.trycloudflare.com/payment/payos/return
PAYOS_CANCEL_URL=https://your-frontend-cloudflare-url.trycloudflare.com/payment/payos/cancel
PAYOS_WEBHOOK_URL=https://your-backend-cloudflare-url.trycloudflare.com/api/payments/webhooks/payos
TICKET_QR_SECRET=replace-with-another-32-character-secret
PAYMENT_PENDING_TTL_MINUTES=15
CASH_PAYMENT_TTL_MINUTES=60
BOOKING_EXPIRY_INTERVAL_MS=30000

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
